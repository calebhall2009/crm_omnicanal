# ========================================
# PRODUCTION ENV TEMPLATE
# ========================================
# Copy to Railway/Render dashboard, NEVER commit real values
# Use their secret manager

# ---- App ----
APP_NAME="Tu CRM"
APP_ENV=production
APP_KEY=                    # Generate: php artisan key:generate --show
APP_DEBUG=false
APP_TIMEZONE=America/Mexico_City
APP_URL=https://tudominio.com

APP_LOCALE=es
APP_FALLBACK_LOCALE=es
APP_FAKER_LOCALE=es_ES

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

# ---- Database (use managed MySQL in prod, NOT the docker container) ----
DB_CONNECTION=mysql
DB_HOST=                    # Set by Railway/Render addon
DB_PORT=3306
DB_DATABASE=
DB_USERNAME=
DB_PASSWORD=

# ---- Session / Cache / Queue ----
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.tudominio.com

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database
CACHE_STORE=database

# ---- Redis (use managed Redis in prod) ----
REDIS_CLIENT=phpredis
REDIS_HOST=
REDIS_PASSWORD=
REDIS_PORT=6379

# ---- Mail (use real provider in prod, NOT log) ----
MAIL_MAILER=smtp             # smtp, ses, mailgun, postmark, etc.
MAIL_HOST=
MAIL_PORT=587
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS=noreply@tudominio.com
MAIL_FROM_NAME="${APP_NAME}"

# ---- External Services (rotate from dev!) ----
GEMINI_API_KEY=
WHATSAPP_API_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_BUSINESS_ACCOUNT_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=

INSTAGRAM_API_TOKEN=
INSTAGRAM_BUSINESS_ACCOUNT_ID=
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=

TELEGRAM_BOT_TOKEN=
TELEGRAM_WEBHOOK_URL=

STRIPE_KEY=pk_live_...
STRIPE_SECRET=sk_live_...
STRIPE_WEBHOOK_SECRET=

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=

# ---- Frontend (Sanctum SPA) ----
SANCTUM_STATEFUL_DOMAINS=tudominio.com,www.tudominio.com
FRONTEND_URL=https://tudominio.com
SESSION_DOMAIN=.tudominio.com

# ---- Inter-service (same as docker-compose, just regenerated) ----
LARAVEL_INTERNAL_URL=http://backend:8000
LARAVEL_INTERNAL_SECRET=    # Generate new, do NOT use dev secret

VITE_APP_NAME="${APP_NAME}"
