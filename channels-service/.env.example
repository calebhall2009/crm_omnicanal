APP_NAME="Channels Service"
APP_ENV=local
PORT=8080

# Database Configuration (MySQL 8 Docker Container)
DB_HOST=db
DB_PORT=3306
DB_DATABASE=laravel_db
DB_USERNAME=laravel_user
DB_PASSWORD=laravel_password

# Redis Configuration (Docker Container)
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

# Gemini AI API Key
GEMINI_API_KEY=your_gemini_api_key_here

# WhatsApp Business API Credentials
WHATSAPP_API_TOKEN=your_whatsapp_api_token_here
WHATSAPP_PHONE_NUMBER_ID=your_whatsapp_phone_number_id_here
WHATSAPP_BUSINESS_ACCOUNT_ID=your_whatsapp_business_account_id_here
WHATSAPP_WEBHOOK_VERIFY_TOKEN=your_whatsapp_webhook_verify_token_here

# Instagram Graph API Credentials
INSTAGRAM_API_TOKEN=your_instagram_api_token_here
INSTAGRAM_BUSINESS_ACCOUNT_ID=your_instagram_business_account_id_here
INSTAGRAM_WEBHOOK_VERIFY_TOKEN=your_instagram_webhook_verify_token_here

# Telegram Bot API Credentials
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here
TELEGRAM_WEBHOOK_URL=your_telegram_webhook_url_here

# Stripe Integration Credentials
STRIPE_KEY=pk_test_your_stripe_publishable_key_here
STRIPE_SECRET=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_stripe_webhook_secret_here

# Cloudflare Turnstile Credentials
TURNSTILE_SITE_KEY=your_turnstile_site_key_here
TURNSTILE_SECRET_KEY=your_turnstile_secret_key_here
