# Frontend Environment Variables (Vite React Client)
# Note: Variables must be prefixed with VITE_ to be exposed to client-side code.

VITE_APP_NAME="Monorepo App"
VITE_APP_ENV=local

# API Base URLs
VITE_BACKEND_API_URL=http://localhost:8000
VITE_CHANNELS_API_URL=http://localhost:8080

# Gemini API Key (Avoid exposing in production frontend if possible, call via backend/channels-service instead)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# Cloudflare Turnstile (Site Key is public, Secret Key goes to backend)
VITE_TURNSTILE_SITE_KEY=your_turnstile_site_key_here

# Stripe Integration (Publishable Key is public, Secret Key goes to backend)
VITE_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Telegram Bot Integration (Bot Username for widgets/links)
VITE_TELEGRAM_BOT_USERNAME=your_bot_username_here
